// Define the 32-bit RISC-V CPU
cpu: CPU.RiscV32 @ sysbus
    cpuType: "rv32i"

// Memory mapping based on your link.ld
flash: Memory.MappedMemory @ sysbus 0x0
    size: 0x40000

ram: Memory.MappedMemory @ sysbus 0x20000000
    size: 0x10000

// Map your custom peripherals as "PythonPeripherals"
// This allows us to script how they behave without writing C++ plugins
sys_gpio: Python.PythonPeripheral @ sysbus 0x40001000
    size: 0x20

timer1: Python.PythonPeripheral @ sysbus 0x40002000
    size: 0x14
