cpu: CPU.RiscV32 @ sysbus
    cpuType: "rv32i"

flash: Memory.MappedMemory @ sysbus 0x0
    size: 0x40000

ram: Memory.MappedMemory @ sysbus 0x20000000
    size: 0x10000

sys_gpio: Python.PythonPeripheral @ sysbus 0x40001000
    size: 0x100
    filename: "/media/vamsi-kiran/SSD_gen41/Example_Embedde_Coding/ZX_8080_MCU/gpio.py"

timer1: Python.PythonPeripheral @ sysbus 0x40002000
    size: 0x100
    filename: "/media/vamsi-kiran/SSD_gen41/Example_Embedde_Coding/ZX_8080_MCU/timer.py"
